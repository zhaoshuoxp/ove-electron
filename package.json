{
  "name": "ove-electron",
  "version": "1.6.0",
  "description": "An open source vector or plasmid editor",
  "main": "main.js",
  "author": "Thomas (tnrich) Willheim <tnrich@teselagen.com>",
  "scripts": {
    "start": "electron . ./pA11990.gb",
    "test": "mocha",
    "prepare-primer3": "node scripts/prepare-primer3.js",
    "prepare-primer3:source": "node scripts/prepare-primer3.js --from-source",
    "validate-primer3": "node scripts/validate-primer3-resources.js",
    "validate-primer3:mac": "node scripts/validate-primer3-resources.js darwin-arm64 darwin-x64",
    "validate-primer3:win": "node scripts/validate-primer3-resources.js win32-x64",
    "validate-primer3:linux": "node scripts/validate-primer3-resources.js linux-x64 linux-arm64",
    "validate-primer3:all": "node scripts/validate-primer3-resources.js darwin-arm64 darwin-x64 win32-x64 linux-x64 linux-arm64",
    "build": "yarn prepare-primer3 && yarn validate-primer3:mac && env-cmd -f .env.example electron-builder --mac --publish never",
    "build-all": "yarn validate-primer3:all && env-cmd -f .env.example electron-builder -wml --publish never",
    "build-win": "yarn validate-primer3:win && env-cmd -f .env.example electron-builder --win portable --x64 --publish never",
    "build-win-nsis": "yarn validate-primer3:win && env-cmd -f .env.example electron-builder --win nsis --x64 --publish never",
    "build-mac": "yarn prepare-primer3 && yarn validate-primer3:mac && env-cmd electron-builder --mac --publish never",
    "build-linux": "yarn validate-primer3:linux && env-cmd electron-builder --linux --publish never",
    "deploy": "yarn validate-primer3:all && env-cmd electron-builder --mac --linux --win --publish always",
    "deploy-win": "yarn validate-primer3:win && electron-builder --win --publish always",
    "deploy-mac": "yarn prepare-primer3 && yarn validate-primer3:mac && env-cmd electron-builder --mac --publish always",
    "deploy-linux": "yarn validate-primer3:linux && env-cmd electron-builder --linux --publish always",
    "generateChangelog": "auto-changelog -p && git add . && git commit -m 'Updating CHANGELOG' && git push"
  },
  "build": {
    "appx": {
      "identityName": "56560Teselagen.OpenVectorEditor",
      "publisher": "CN=D373F92F-3481-433F-9DC5-0BE55DE5500D",
      "publisherDisplayName": "Teselagen",
      "applicationId": "OpenVectorEditor",
      "displayName": "OpenVectorEditor"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": {
        "target": "deb",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      "icon": "build/icon.icns"
    },
    "productName": "OpenVectorEditor",
    "publish": {
      "provider": "github",
      "repo": "ove-electron",
      "owner": "tnrich"
    },
    "afterSign": "src/misc/notarize.js",
    "mac": {
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      "entitlements": "src/misc/entitlements.mac.plist",
      "entitlementsInherit": "src/misc/entitlements.mac.plist"
    },
    "appId": "com.teselagen.openVectorEditor",
    "extraResources": [
      {
        "from": "bin/primer3",
        "to": "bin/primer3",
        "filter": [
          "**/*"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": "json"
      },
      {
        "ext": "gb"
      },
      {
        "ext": "dna"
      },
      {
        "ext": "gbk"
      },
      {
        "ext": "gp"
      },
      {
        "ext": "fas"
      },
      {
        "ext": "fasta"
      },
      {
        "ext": "fa"
      },
      {
        "ext": "fna"
      },
      {
        "ext": "ffn"
      },
      {
        "ext": "gff"
      },
      {
        "ext": "gff3"
      }
    ]
  },
  "repository": "https://github.com/electron/ove-electron",
  "keywords": [
    "Electron",
    "open-vector-editor",
    "plasmid",
    "editor",
    "dna",
    "ove"
  ],
  "license": "MIT",
  "devDependencies": {
    "auto-changelog": "^2.4.0",
    "electron": "22.0.0",
    "electron-builder": "^23.6.0",
    "electron-notarize": "^1.2.1",
    "env-cmd": "^10.1.0",
    "eslint": "^8.28.0",
    "eslint-config-teselagen": "^6.0.16",
    "mocha": "^10.1.0",
    "spectron": "^19.0.0"
  },
  "dependencies": {
    "bio-parsers": "^9.0.1",
    "electron-updater": "^5.3.0",
    "electron-window-state": "^5.0.3",
    "open-vector-editor": "^18.1.53",
    "ove-auto-annotate": "^0.0.5",
    "querystring": "^0.2.1",
    "ve-range-utils": "^2.6.6",
    "ve-sequence-utils": "^5.2.8"
  }
}
